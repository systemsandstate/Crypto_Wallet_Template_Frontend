# Expo Go — copy to .env and adjust for your server
EXPO_PUBLIC_API_URL=https://api.mohsinraza.xyz/api
EXPO_PUBLIC_HOST=mohsinraza.xyz
# Required when running Expo as root (VPS) — avoids Electron DevTools crash
EXPO_UNSTABLE_HEADLESS=1
# Required for remote push (iOS Expo Go). Run: npx eas login && npx eas init
EXPO_PUBLIC_EAS_PROJECT_ID=

# GasFree (TRC20 USDT fees) — https://docs.gasfree.io/
EXPO_PUBLIC_GASFREE_API_URL=https://open.gasfree.io/tron
EXPO_PUBLIC_GASFREE_API_KEY=
EXPO_PUBLIC_GASFREE_API_SECRET=
# Optional: pin a service provider (otherwise first from /api/v1/config/provider/all)
EXPO_PUBLIC_GASFREE_SERVICE_PROVIDER=
EXPO_PUBLIC_TRON_RPC_URL=https://api.trongrid.io

# Candide (ERC20 / BEP20 / Polygon USDT fees via EIP-7702) — https://dashboard.candide.dev
EXPO_PUBLIC_CANDIDE_API_KEY=
